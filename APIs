openapi: 3.0.3
info:
  title: XAI Platform API (Explainable Recommender Systems)
  version: "1.0.0"
  description: >
    REST API для запроса объяснений рекомендательных решений, хранения логов/метрик,
    сравнения моделей, выявления подозрительных рекомендаций и экспорта отчетов.
servers:
  # Added by API Auto Mocking Plugin
  - description: SwaggerHub API Auto Mocking
    url: https://virtserver.swaggerhub.com/none-86f/Xai/1.0.0
  - url: https://api.example.com
    description: Production (placeholder)
  - url: https://staging-api.example.com
    description: Staging (placeholder)

tags:
  - name: Tenants
    description: Управление организациями-клиентами (Tenant)
  - name: API Keys
    description: Управление ключами доступа клиентов к API
  - name: Models
    description: Регистрация и управление рекомендательными моделями клиентов
  - name: Explain
    description: Построение объяснений (on-demand) и контрфактических объяснений
  - name: Batch
    description: Пакетная генерация объяснений (job + polling)
  - name: Logs
    description: История запросов и объяснений
  - name: Metrics
    description: Метрики качества объяснений и агрегаты по моделям
  - name: Analysis
    description: Сравнение моделей, выявление подозрительных рекомендаций, bias-отчеты
  - name: Reports
    description: Экспорт отчетов и результатов (JSON/CSV)
  - name: Auth
    description: Аутентификация/сессия Web UI
  - name: System
    description: Системные эндпоинты (health)

paths:

  /health:
    get:
      tags: [System]
      summary: Health check
      operationId: healthCheck
      responses:
        "200":
          description: Service is healthy
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/HealthResponse"

  # -------------------------
  # Auth (для Web UI)
  # -------------------------
  /auth/login:
    post:
      tags: [Auth]
      summary: Login for Web UI (JWT)
      description: >
        Аутентификация пользователя веб-интерфейса (роль: admin/analyst).
        Возвращает JWT access token.
      operationId: login
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/LoginRequest"
      responses:
        "200":
          description: Auth success
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/LoginResponse"
        "401":
          description: Invalid credentials
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /auth/me:
    get:
      tags: [Auth]
      summary: Current user info (Web UI)
      operationId: getMe
      security:
        - BearerAuth: []
      responses:
        "200":
          description: Current user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/UserInfo"
        "401":
          description: Missing/invalid token
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /tenants:
    post:
      tags: [Tenants]
      summary: Create tenant (UC-01)
      description: >
        Создание организации-клиента (Tenant) администратором системы.
      operationId: createTenant
      security:
        - BearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateTenantRequest"
      responses:
        "201":
          description: Tenant created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Tenant"
        "400":
          description: Validation error
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "401":
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "403":
          description: Forbidden (requires admin role)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

    get:
      tags: [Tenants]
      summary: List tenants
      operationId: listTenants
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/Page"
        - $ref: "#/components/parameters/PageSize"
        - $ref: "#/components/parameters/Sort"
      responses:
        "200":
          description: Tenants page
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PagedTenants"
        "401":
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /tenants/{tenantId}:
    get:
      tags: [Tenants]
      summary: Get tenant by id
      operationId: getTenant
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
      responses:
        "200":
          description: Tenant
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Tenant"
        "404":
          description: Tenant not found
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

    patch:
      tags: [Tenants]
      summary: Update tenant
      operationId: updateTenant
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateTenantRequest"
      responses:
        "200":
          description: Updated tenant
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Tenant"
        "400":
          description: Validation error
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "403":
          description: Forbidden (requires admin role)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  # -------------------------
  # API Keys (UC-02)
  # -------------------------
  /tenants/{tenantId}/api-keys:
    post:
      tags: [API Keys]
      summary: Create API key for tenant (UC-02)
      description: >
        Генерация ключа доступа для интеграции клиента с XAI API.
      operationId: createApiKey
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
      requestBody:
        required: false
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateApiKeyRequest"
      responses:
        "201":
          description: API key created (secret returned only once)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ApiKeyCreated"
        "403":
          description: Forbidden (requires admin role)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

    get:
      tags: [API Keys]
      summary: List API keys for tenant
      operationId: listApiKeys
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
        - $ref: "#/components/parameters/Page"
        - $ref: "#/components/parameters/PageSize"
      responses:
        "200":
          description: API keys page
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PagedApiKeys"

  /tenants/{tenantId}/api-keys/{apiKeyId}:
    patch:
      tags: [API Keys]
      summary: Revoke/disable API key
      operationId: updateApiKey
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
        - $ref: "#/components/parameters/ApiKeyId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateApiKeyRequest"
      responses:
        "200":
          description: Updated API key
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ApiKey"
        "404":
          description: API key not found
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  # -------------------------
  # Models (UC-03)
  # -------------------------
  /tenants/{tenantId}/models:
    post:
      tags: [Models]
      summary: Register client recommendation model (UC-03)
      operationId: registerModel
      security:
        - ApiKeyAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/RegisterModelRequest"
      responses:
        "201":
          description: Model registered
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Model"
        "400":
          description: Validation error
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "401":
          description: Unauthorized (missing/invalid API key)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

    get:
      tags: [Models]
      summary: List models for tenant
      operationId: listModels
      security:
        - ApiKeyAuth: []
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
        - $ref: "#/components/parameters/Page"
        - $ref: "#/components/parameters/PageSize"
        - name: status
          in: query
          required: false
          schema:
            type: string
            enum: [ACTIVE, DISABLED]
      responses:
        "200":
          description: Models page
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PagedModels"

  /tenants/{tenantId}/models/{modelId}:
    get:
      tags: [Models]
      summary: Get model
      operationId: getModel
      security:
        - ApiKeyAuth: []
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
        - $ref: "#/components/parameters/ModelId"
      responses:
        "200":
          description: Model
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Model"
        "404":
          description: Model not found
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

    patch:
      tags: [Models]
      summary: Update model (e.g., disable)
      operationId: updateModel
      security:
        - ApiKeyAuth: []
      parameters:
        - $ref: "#/components/parameters/TenantId"
        - $ref: "#/components/parameters/ModelId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateModelRequest"
      responses:
        "200":
          description: Updated model
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Model"

  # -------------------------
  # Explain on-demand (UC-04..UC-06) + idempotency FR-23/24
  # -------------------------
  /xai/explain:
    post:
      tags: [Explain]
      summary: Build explanation for a recommendation (UC-04..UC-06)
      description: >
        Построение объяснения рекомендации в реальном времени.
        Поле request_id обязательно и используется для идемпотентности:
        повторный запрос с тем же request_id и тем же payload возвращает прежний результат
        (или статус выполнения), без повторного расчёта.
      operationId: explain
      security:
        - ApiKeyAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/ExplainRequest"
      responses:
        "200":
          description: Explanation response
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExplainResponse"
        "400":
          description: Validation error / not enough context
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "401":
          description: Unauthorized (missing/invalid API key)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "429":
          description: Too many requests (rate limit)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "500":
          description: Explanation failed
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "503":
          description: Service unavailable / timeout
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /xai/explain/counterfactual:
    post:
      tags: [Explain]
      summary: Generate counterfactual explanation (UC-13)
      operationId: counterfactualExplain
      security:
        - ApiKeyAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CounterfactualRequest"
      responses:
        "200":
          description: Counterfactual response
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CounterfactualResponse"
        "400":
          description: Validation error
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "429":
          description: Rate limit
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  # -------------------------
  # Batch (FR-14) без брокеров: job + polling
  # -------------------------
  /xai/explain/batch:
    post:
      tags: [Batch]
      summary: Create batch explain job (FR-14)
      operationId: createBatchJob
      security:
        - ApiKeyAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BatchExplainCreateRequest"
      responses:
        "202":
          description: Job accepted
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/BatchJobAccepted"
        "400":
          description: Validation error
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"
        "429":
          description: Rate limit
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /xai/explain/batch/{jobId}:
    get:
      tags: [Batch]
      summary: Get batch job status/result
      operationId: getBatchJob
      security:
        - ApiKeyAuth: []
      parameters:
        - $ref: "#/components/parameters/JobId"
      responses:
        "200":
          description: Job status/result
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/BatchJobStatus"
        "404":
          description: Job not found
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  # -------------------------
  # Logs (UC-08/UC-09) — просмотр истории (Web UI)
  # -------------------------
  /xai/logs:
    get:
      tags: [Logs]
      summary: Query explanation logs (UC-09)
      operationId: queryLogs
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/Page"
        - $ref: "#/components/parameters/PageSize"
        - name: tenant_id
          in: query
          required: false
          schema: { type: string }
        - name: model_id
          in: query
          required: false
          schema: { type: string }
        - name: request_id
          in: query
          required: false
          schema: { type: string, format: uuid }
        - name: from
          in: query
          required: false
          schema: { type: string, format: date-time }
        - name: to
          in: query
          required: false
          schema: { type: string, format: date-time }
        - name: status
          in: query
          required: false
          schema:
            type: string
            enum: [SUCCEEDED, FAILED, RUNNING]
      responses:
        "200":
          description: Logs page
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PagedLogs"
        "401":
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /xai/logs/{logId}:
    get:
      tags: [Logs]
      summary: Get log entry
      operationId: getLog
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/LogId"
      responses:
        "200":
          description: Log entry
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExplanationLog"
        "404":
          description: Not found
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  # -------------------------
  # Metrics (UC-10)
  # -------------------------
  /xai/metrics/models/{modelId}:
    get:
      tags: [Metrics]
      summary: Get XAI metrics by model (UC-10)
      operationId: getModelMetrics
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/ModelIdPath"
        - name: from
          in: query
          required: false
          schema: { type: string, format: date-time }
        - name: to
          in: query
          required: false
          schema: { type: string, format: date-time }
        - name: aggregation
          in: query
          required: false
          schema:
            type: string
            enum: [NONE, HOURLY, DAILY, WEEKLY]
            default: DAILY
      responses:
        "200":
          description: Metrics series/aggregate
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ModelMetricsResponse"

  # -------------------------
  # Comparison (UC-11 / FR-09)
  # -------------------------
  /xai/compare:
    post:
      tags: [Analysis]
      summary: Compare explanations of two models on same dataset (UC-11)
      operationId: compareModels
      security:
        - BearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CompareRequest"
      responses:
        "200":
          description: Comparison report
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CompareResponse"
        "400":
          description: Validation error
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  # -------------------------
  # Suspicious recommendations (UC-12)
  # -------------------------
  /xai/suspicious:
    post:
      tags: [Analysis]
      summary: Find suspicious recommendations by metrics thresholds (UC-12)
      operationId: findSuspicious
      security:
        - BearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/SuspiciousQueryRequest"
      responses:
        "200":
          description: Suspicious items
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/SuspiciousQueryResponse"

  # -------------------------
  # Bias report (FR-12)
  # -------------------------
  /xai/bias/report:
    post:
      tags: [Analysis]
      summary: Generate bias detection report (FR-12)
      operationId: biasReport
      security:
        - BearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BiasReportRequest"
      responses:
        "200":
          description: Bias report
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/BiasReportResponse"

  # -------------------------
  # Export / Reports (UC-14 / FR-15)
  # -------------------------
  /reports:
    post:
      tags: [Reports]
      summary: Create export report (UC-14 / FR-15)
      operationId: createReport
      security:
        - BearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateReportRequest"
      responses:
        "202":
          description: Report job accepted
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ReportAccepted"

  /reports/{reportId}:
    get:
      tags: [Reports]
      summary: Get report status
      operationId: getReportStatus
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/ReportId"
      responses:
        "200":
          description: Report status
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ReportStatus"

  /reports/{reportId}/download:
    get:
      tags: [Reports]
      summary: Download generated report (JSON/CSV)
      operationId: downloadReport
      security:
        - BearerAuth: []
      parameters:
        - $ref: "#/components/parameters/ReportId"
        - name: format
          in: query
          required: true
          schema:
            type: string
            enum: [json, csv]
      responses:
        "200":
          description: Report file
          content:
            application/json:
              schema:
                type: object
                additionalProperties: true
            text/csv:
              schema:
                type: string
        "409":
          description: Report not ready
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

components:

  securitySchemes:
    ApiKeyAuth:
      type: apiKey
      in: header
      name: X-API-Key
    BearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT

  parameters:
    TenantId:
      name: tenantId
      in: path
      required: true
      schema: { type: string }
    ModelId:
      name: modelId
      in: path
      required: true
      schema: { type: string }
    ModelIdPath:
      name: modelId
      in: path
      required: true
      schema: { type: string }
    ApiKeyId:
      name: apiKeyId
      in: path
      required: true
      schema: { type: string }
    LogId:
      name: logId
      in: path
      required: true
      schema: { type: string }
    JobId:
      name: jobId
      in: path
      required: true
      schema: { type: string }
    ReportId:
      name: reportId
      in: path
      required: true
      schema: { type: string }
    Page:
      name: page
      in: query
      required: false
      schema: { type: integer, minimum: 1, default: 1 }
    PageSize:
      name: page_size
      in: query
      required: false
      schema: { type: integer, minimum: 1, maximum: 200, default: 50 }
    Sort:
      name: sort
      in: query
      required: false
      schema:
        type: string
        example: "created_at:desc"

  schemas:

    # --- Common
    ErrorResponse:
      type: object
      required: [code, message]
      properties:
        code:
          type: string
          example: "VALIDATION_ERROR"
        message:
          type: string
          example: "request_id is required"
        details:
          type: object
          additionalProperties: true
        trace_id:
          type: string
          description: Correlation id for troubleshooting

    HealthResponse:
      type: object
      required: [status, time]
      properties:
        status:
          type: string
          enum: [OK]
        time:
          type: string
          format: date-time
        version:
          type: string

    PagedMeta:
      type: object
      required: [page, page_size, total]
      properties:
        page: { type: integer }
        page_size: { type: integer }
        total: { type: integer }

    # --- Auth / Users
    LoginRequest:
      type: object
      required: [username, password]
      properties:
        username: { type: string }
        password: { type: string, format: password }

    LoginResponse:
      type: object
      required: [access_token, token_type, expires_in]
      properties:
        access_token: { type: string }
        token_type: { type: string, example: "Bearer" }
        expires_in: { type: integer, example: 3600 }

    UserInfo:
      type: object
      required: [user_id, username, roles]
      properties:
        user_id: { type: string }
        username: { type: string }
        roles:
          type: array
          items:
            type: string
            enum: [ADMIN, ANALYST]

    # --- Tenants
    CreateTenantRequest:
      type: object
      required: [name]
      properties:
        name:
          type: string
          example: "Ozon Analytics"
        description:
          type: string
        external_ref:
          type: string
          description: Optional external identifier in client's system

    UpdateTenantRequest:
      type: object
      properties:
        name: { type: string }
        description: { type: string }
        status:
          type: string
          enum: [ACTIVE, DISABLED]

    Tenant:
      type: object
      required: [tenant_id, name, status, created_at]
      properties:
        tenant_id: { type: string }
        name: { type: string }
        description: { type: string }
        status:
          type: string
          enum: [ACTIVE, DISABLED]
        created_at: { type: string, format: date-time }

    PagedTenants:
      type: object
      required: [data, meta]
      properties:
        data:
          type: array
          items: { $ref: "#/components/schemas/Tenant" }
        meta: { $ref: "#/components/schemas/PagedMeta" }

    # --- API Keys
    CreateApiKeyRequest:
      type: object
      properties:
        name:
          type: string
          example: "prod-backend-key"
        expires_at:
          type: string
          format: date-time

    ApiKey:
      type: object
      required: [api_key_id, tenant_id, name, status, created_at]
      properties:
        api_key_id: { type: string }
        tenant_id: { type: string }
        name: { type: string }
        status:
          type: string
          enum: [ACTIVE, REVOKED]
        created_at: { type: string, format: date-time }
        expires_at: { type: string, format: date-time, nullable: true }
        last_used_at: { type: string, format: date-time, nullable: true }

    ApiKeyCreated:
      allOf:
        - $ref: "#/components/schemas/ApiKey"
        - type: object
          required: [secret]
          properties:
            secret:
              type: string
              description: Returned only once. Store securely.

    UpdateApiKeyRequest:
      type: object
      required: [status]
      properties:
        status:
          type: string
          enum: [REVOKED]

    PagedApiKeys:
      type: object
      required: [data, meta]
      properties:
        data:
          type: array
          items: { $ref: "#/components/schemas/ApiKey" }
        meta: { $ref: "#/components/schemas/PagedMeta" }

    # --- Models
    RegisterModelRequest:
      type: object
      required: [model_name, model_type, version]
      properties:
        model_name:
          type: string
          example: "RecSys-v2"
        model_type:
          type: string
          example: "TwoTower"
        version:
          type: string
          example: "2.1.0"
        parameters:
          type: object
          additionalProperties: true
          description: Free-form model parameters/config
        supports_signals:
          type: boolean
          default: false
          description: Whether model can provide model-specific explanation signals

    UpdateModelRequest:
      type: object
      properties:
        status:
          type: string
          enum: [ACTIVE, DISABLED]
        parameters:
          type: object
          additionalProperties: true

    Model:
      type: object
      required: [model_id, tenant_id, model_name, model_type, version, status, created_at]
      properties:
        model_id: { type: string }
        tenant_id: { type: string }
        model_name: { type: string }
        model_type: { type: string }
        version: { type: string }
        status:
          type: string
          enum: [ACTIVE, DISABLED]
        supports_signals: { type: boolean }
        parameters:
          type: object
          additionalProperties: true
        created_at: { type: string, format: date-time }

    PagedModels:
      type: object
      required: [data, meta]
      properties:
        data:
          type: array
          items: { $ref: "#/components/schemas/Model" }
        meta: { $ref: "#/components/schemas/PagedMeta" }

    # --- Explain
    ExplainRequest:
      type: object
      required: [request_id, tenant_id, model_id, user, item, context]
      properties:
        request_id:
          type: string
          format: uuid
          description: Idempotency & tracing key
        tenant_id:
          type: string
        model_id:
          type: string
        user:
          type: object
          additionalProperties: true
          description: User profile/features (free-form)
        item:
          type: object
          additionalProperties: true
          description: Recommended item features (free-form)
        context:
          type: object
          additionalProperties: true
          description: Context features (time/device/history, etc.)
        rec_score:
          type: number
          format: double
          description: Optional recommendation score
        model_signals:
          type: object
          additionalProperties: true
          description: Optional model-specific signals (embeddings, rules, etc.)
        method:
          type: string
          description: Selected XAI method (e.g., SHAP/LIME/Anchors/Counterfactual)
        max_factors:
          type: integer
          minimum: 1
          maximum: 50
          default: 50

    ExplainResponse:
      type: object
      required: [request_id, status]
      properties:
        request_id:
          type: string
          format: uuid
        status:
          type: string
          enum: [SUCCEEDED, RUNNING, FAILED]
        explanation:
          $ref: "#/components/schemas/Explanation"
        metrics:
          $ref: "#/components/schemas/XaiMetrics"
        warnings:
          type: array
          items: { type: string }
        trace_id:
          type: string

    Explanation:
      type: object
      properties:
        text:
          type: string
          example: "Рекомендовано, потому что вам нравятся похожие товары и вы часто покупаете в этой категории."
        factors:
          type: array
          maxItems: 50
          items:
            $ref: "#/components/schemas/FactorContribution"

    FactorContribution:
      type: object
      required: [feature, contribution]
      properties:
        feature:
          type: string
          example: "category_affinity.electronics"
        contribution:
          type: number
          format: double
          example: 0.42
        direction:
          type: string
          enum: [POSITIVE, NEGATIVE, NEUTRAL]
        raw_value:
          type: string
          description: Optional raw feature value serialized as string

    XaiMetrics:
      type: object
      description: Quality metrics for explanation
      properties:
        fidelity: { type: number, format: double }
        stability: { type: number, format: double }
        sparsity: { type: number, format: double }
        sensitivity: { type: number, format: double }

    # --- Counterfactual
    CounterfactualRequest:
      type: object
      required: [request_id, tenant_id, model_id, user, item, context]
      properties:
        request_id: { type: string, format: uuid }
        tenant_id: { type: string }
        model_id: { type: string }
        user:
          type: object
          additionalProperties: true
        item:
          type: object
          additionalProperties: true
        context:
          type: object
          additionalProperties: true
        desired_outcome:
          type: string
          enum: [INCREASE_SCORE, DECREASE_SCORE, FLIP_RECOMMENDATION]
        method:
          type: string
          default: "COUNTERFACTUAL"

    CounterfactualResponse:
      type: object
      required: [request_id, counterfactuals]
      properties:
        request_id: { type: string, format: uuid }
        counterfactuals:
          type: array
          items:
            $ref: "#/components/schemas/CounterfactualExample"
        metrics:
          $ref: "#/components/schemas/XaiMetrics"

    CounterfactualExample:
      type: object
      required: [changes]
      properties:
        changes:
          type: array
          items:
            $ref: "#/components/schemas/FeatureChange"
        explanation:
          type: string
          example: "Если увеличить интерес к категории 'спорт' и снизить частоту покупок 'электроника', рекомендация изменится."

    FeatureChange:
      type: object
      required: [feature, from, to]
      properties:
        feature: { type: string }
        from: { type: string }
        to: { type: string }

    # --- Batch
    BatchExplainCreateRequest:
      type: object
      required: [tenant_id, model_id, items]
      properties:
        tenant_id: { type: string }
        model_id: { type: string }
        method: { type: string }
        items:
          type: array
          description: Up to 100 items per batch request
          maxItems: 100
          items:
            $ref: "#/components/schemas/ExplainRequestItem"

    ExplainRequestItem:
      type: object
      required: [request_id, user, item, context]
      properties:
        request_id: { type: string, format: uuid }
        user:
          type: object
          additionalProperties: true
        item:
          type: object
          additionalProperties: true
        context:
          type: object
          additionalProperties: true
        rec_score: { type: number, format: double }
        model_signals:
          type: object
          additionalProperties: true

    BatchJobAccepted:
      type: object
      required: [job_id, status, accepted_at]
      properties:
        job_id: { type: string }
        status:
          type: string
          enum: [RUNNING]
        accepted_at: { type: string, format: date-time }

    BatchJobStatus:
      type: object
      required: [job_id, status]
      properties:
        job_id: { type: string }
        status:
          type: string
          enum: [RUNNING, SUCCEEDED, FAILED]
        started_at: { type: string, format: date-time, nullable: true }
        finished_at: { type: string, format: date-time, nullable: true }
        results:
          type: array
          items:
            $ref: "#/components/schemas/ExplainResponse"
        error:
          type: string
          nullable: true

    # --- Logs
    ExplanationLog:
      type: object
      required: [log_id, request_id, tenant_id, model_id, status, created_at]
      properties:
        log_id: { type: string }
        request_id: { type: string, format: uuid }
        tenant_id: { type: string }
        model_id: { type: string }
        status:
          type: string
          enum: [SUCCEEDED, FAILED, RUNNING]
        created_at: { type: string, format: date-time }
        duration_ms: { type: integer, minimum: 0 }
        payload_size_bytes: { type: integer, minimum: 0 }
        request:
          $ref: "#/components/schemas/ExplainRequest"
        response:
          $ref: "#/components/schemas/ExplainResponse"

    PagedLogs:
      type: object
      required: [data, meta]
      properties:
        data:
          type: array
          items: { $ref: "#/components/schemas/ExplanationLog" }
        meta: { $ref: "#/components/schemas/PagedMeta" }

    # --- Metrics response
    ModelMetricsResponse:
      type: object
      required: [model_id, aggregation, data]
      properties:
        model_id: { type: string }
        aggregation:
          type: string
          enum: [NONE, HOURLY, DAILY, WEEKLY]
        data:
          type: array
          items:
            $ref: "#/components/schemas/MetricsPoint"

    MetricsPoint:
      type: object
      required: [timestamp, metrics]
      properties:
        timestamp: { type: string, format: date-time }
        metrics:
          $ref: "#/components/schemas/XaiMetrics"
        count:
          type: integer
          minimum: 0

    # --- Compare
    CompareRequest:
      type: object
      required: [tenant_id, model_a_id, model_b_id, dataset]
      properties:
        tenant_id: { type: string }
        model_a_id: { type: string }
        model_b_id: { type: string }
        dataset:
          type: array
          maxItems: 100
          items:
            $ref: "#/components/schemas/ExplainRequestItem"
        method:
          type: string
          description: Optional XAI method used for comparison

    CompareResponse:
      type: object
      required: [model_a_id, model_b_id, summary]
      properties:
        model_a_id: { type: string }
        model_b_id: { type: string }
        summary:
          type: object
          additionalProperties: true
          description: High-level comparison results
        per_item:
          type: array
          items:
            $ref: "#/components/schemas/ComparePerItem"

    ComparePerItem:
      type: object
      required: [request_id, model_a, model_b]
      properties:
        request_id: { type: string, format: uuid }
        model_a:
          $ref: "#/components/schemas/ExplainResponse"
        model_b:
          $ref: "#/components/schemas/ExplainResponse"

    # --- Suspicious
    SuspiciousQueryRequest:
      type: object
      required: [tenant_id]
      properties:
        tenant_id: { type: string }
        model_id: { type: string }
        thresholds:
          type: object
          description: Metrics thresholds; if metric violates threshold -> suspicious
          properties:
            fidelity_max: { type: number, format: double, nullable: true }
            fidelity_min: { type: number, format: double, nullable: true }
            stability_max: { type: number, format: double, nullable: true }
            stability_min: { type: number, format: double, nullable: true }
            sparsity_max: { type: number, format: double, nullable: true }
            sparsity_min: { type: number, format: double, nullable: true }
            sensitivity_max: { type: number, format: double, nullable: true }
            sensitivity_min: { type: number, format: double, nullable: true }
        from: { type: string, format: date-time, nullable: true }
        to: { type: string, format: date-time, nullable: true }
        limit:
          type: integer
          minimum: 1
          maximum: 500
          default: 100

    SuspiciousQueryResponse:
      type: object
      required: [items]
      properties:
        items:
          type: array
          items:
            $ref: "#/components/schemas/SuspiciousItem"

    SuspiciousItem:
      type: object
      required: [log_id, request_id, model_id, metrics]
      properties:
        log_id: { type: string }
        request_id: { type: string, format: uuid }
        model_id: { type: string }
        metrics: { $ref: "#/components/schemas/XaiMetrics" }
        reason:
          type: string
          example: "Low fidelity"

    # --- Bias report
    BiasReportRequest:
      type: object
      required: [tenant_id, model_id, group_by]
      properties:
        tenant_id: { type: string }
        model_id: { type: string }
        group_by:
          type: array
          items: { type: string }
          example: ["gender", "age_bucket"]
        from: { type: string, format: date-time, nullable: true }
        to: { type: string, format: date-time, nullable: true }

    BiasReportResponse:
      type: object
      required: [tenant_id, model_id, groups]
      properties:
        tenant_id: { type: string }
        model_id: { type: string }
        groups:
          type: array
          items:
            $ref: "#/components/schemas/BiasGroupResult"
        summary:
          type: object
          additionalProperties: true

    BiasGroupResult:
      type: object
      required: [group_key, metrics]
      properties:
        group_key:
          type: object
          additionalProperties: true
          example: {"gender":"F","age_bucket":"25-34"}
        metrics:
          type: object
          additionalProperties: true
        flags:
          type: array
          items: { type: string }

    # --- Reports
    CreateReportRequest:
      type: object
      required: [tenant_id, scope, format]
      properties:
        tenant_id: { type: string }
        scope:
          type: string
          enum: [LOGS, METRICS, COMPARISON, BIAS, SUSPICIOUS]
        format:
          type: string
          enum: [json, csv]
        params:
          type: object
          additionalProperties: true
          description: Filters/params for chosen scope

    ReportAccepted:
      type: object
      required: [report_id, status]
      properties:
        report_id: { type: string }
        status:
          type: string
          enum: [RUNNING]

    ReportStatus:
      type: object
      required: [report_id, status, created_at]
      properties:
        report_id: { type: string }
        status:
          type: string
          enum: [RUNNING, SUCCEEDED, FAILED]
        created_at: { type: string, format: date-time }
        finished_at: { type: string, format: date-time, nullable: true }
        error: { type: string, nullable: true }
        download_url:
          type: string
          nullable: true
          description: Optional pre-signed URL if you implement it
